---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">
  <section class="py-24">
    <div class="container-site">
      <h1 class="text-5xl font-medium text-ink mb-12">CONTACT ME</h1>

      <div class="contact-case-shell mx-auto w-full">
        <div class="contact-panel rounded-lg border border-line overflow-hidden">
          <div
            id="email-card"
            class="email-card"
            role="button"
            tabindex="0"
            aria-label="Reveal email address"
          >
            <button id="email-copy" type="button" class="email-copy" aria-label="Copy email address" tabindex="-1" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
            </button>
            <div class="email-row">
              <div id="email-display" class="email-display" aria-live="polite"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const setupEmailCard = () => {
      const ascii = `!"#$%&'()*+,-./:;<=>?@[\\]^_{|}~ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789`;
      const codes = [114, 111, 110, 109, 101, 99, 107, 64, 103, 109, 97, 105, 108, 46, 99, 111, 109];
      const card = document.getElementById('email-card');
      const display = document.getElementById('email-display');
      const copy = document.getElementById('email-copy');
      if (!card || !display || !copy) return () => {};

      display.textContent = '';
      card.classList.remove('revealed', 'pulse');
      display.style.setProperty('--email-char-count', String(codes.length));

      const chars: HTMLSpanElement[] = [];
      const phases: number[] = [];
      const hovered: boolean[] = [];
      let revealed = false;

      const nextChar = (index: number) => {
        phases[index] = (phases[index] + 1 + (index % 3)) % ascii.length;
        return ascii[phases[index]];
      };

      const resetToScramble = () => {
        if (!revealed) return;
        revealed = false;
        card.classList.remove('revealed', 'pulse');
        chars.forEach((span, index) => {
          hovered[index] = false;
          span.textContent = nextChar(index);
        });
      };

      codes.forEach((code, index) => {
        const span = document.createElement('span');
        span.className = 'email-char';
        span.dataset.code = String(code);
        phases.push((index * 7) % ascii.length);
        hovered.push(false);
        span.textContent = nextChar(index);
        span.addEventListener('mouseenter', () => {
          if (revealed) return;
          hovered[index] = true;
          span.textContent = String.fromCharCode(code).toUpperCase();
        });
        span.addEventListener('mouseleave', () => {
          if (revealed) return;
          hovered[index] = false;
          span.textContent = nextChar(index);
        });
        display.appendChild(span);
        chars.push(span);
      });

      const timer = window.setInterval(() => {
        if (revealed) return;
        chars.forEach((span, index) => {
          if (hovered[index]) return;
          span.textContent = nextChar(index);
        });
      }, 24);

      const revealAll = () => {
        if (revealed) return;
        revealed = true;
        chars.forEach((span) => {
          const code = Number(span.dataset.code);
          span.textContent = String.fromCharCode(code).toUpperCase();
        });
        card.classList.add('revealed', 'pulse');
        window.setTimeout(() => card.classList.remove('pulse'), 320);
      };

      const onCardKeydown = (event: KeyboardEvent) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        revealAll();
      };

      const onDocumentClick = (event: MouseEvent) => {
        if (!revealed) return;
        if (card.contains(event.target as Node)) return;
        resetToScramble();
      };

      const onPageHidden = () => {
        if (document.hidden) resetToScramble();
      };

      const onWindowBlur = () => {
        resetToScramble();
      };

      const onCopyClick = async (event: MouseEvent) => {
        event.stopPropagation();
        if (!revealed) return;
        const value = chars.map((span) => String.fromCharCode(Number(span.dataset.code))).join('');
        try {
          await navigator.clipboard.writeText(value);
          copy.classList.add('copied');
          window.setTimeout(() => copy.classList.remove('copied'), 240);
        } catch {}
      };

      card.addEventListener('click', revealAll);
      card.addEventListener('keydown', onCardKeydown);
      copy.addEventListener('click', onCopyClick);
      document.addEventListener('click', onDocumentClick);
      document.addEventListener('visibilitychange', onPageHidden);
      window.addEventListener('blur', onWindowBlur);

      return () => {
        window.clearInterval(timer);
        card.removeEventListener('click', revealAll);
        card.removeEventListener('keydown', onCardKeydown);
        copy.removeEventListener('click', onCopyClick);
        document.removeEventListener('click', onDocumentClick);
        document.removeEventListener('visibilitychange', onPageHidden);
        window.removeEventListener('blur', onWindowBlur);
      };
    };

    let teardownEmailCard = setupEmailCard();

    document.addEventListener('astro:before-swap', () => {
      teardownEmailCard();
      teardownEmailCard = () => {};
    });

    document.addEventListener('astro:after-swap', () => {
      teardownEmailCard();
      teardownEmailCard = setupEmailCard();
    });

    window.addEventListener('beforeunload', () => {
      teardownEmailCard();
    });
  </script>
</BaseLayout>

<style>
  .contact-case-shell {
    max-width: 100%;
  }

  @media (min-width: 768px) {
    .contact-case-shell {
      max-width: 100%;
    }
  }

  .contact-panel {
    --email-card-width: 494px;
    --email-card-height: 246px;
    position: relative;
    width: min(100%, calc(var(--email-card-width) * 1.4));
    height: calc(var(--email-card-height) * 1.4);
    margin: 0 auto;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(1200px 300px at 20% -40%, rgb(45 212 191 / 0.12), transparent 40%), var(--color-surface-sunken);
  }

  .contact-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgb(255 255 255 / 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(255 255 255 / 0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    animation: grid-drift 9s linear infinite;
    pointer-events: none;
  }

  .contact-panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent, rgb(255 255 255 / 0.03), transparent);
    animation: scanline 4.8s linear infinite;
    pointer-events: none;
  }

  .email-card {
    position: relative;
    z-index: 1;
    width: var(--email-card-width);
    height: var(--email-card-height);
    margin: 0;
    border: 1px solid var(--color-line-strong);
    border-radius: 12px;
    background: rgb(0 0 0 / 0.55);
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    cursor: pointer;
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }

  .email-card:hover {
    border-color: color-mix(in srgb, var(--color-accent) 60%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-accent) 20%, transparent), 0 0 24px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .email-row {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .email-display {
    display: grid;
    grid-template-columns: repeat(var(--email-char-count), 24px);
    justify-content: center;
    justify-items: center;
    align-items: center;
    gap: 2px;
    min-height: 48px;
  }

  .email-char {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 36px;
    flex-shrink: 0;
    overflow: hidden;
    white-space: nowrap;
    border-radius: 6px;
    font-family: theme('fontFamily.mono');
    font-size: 24px;
    line-height: 1;
    letter-spacing: 0;
    color: rgb(255 255 255);
    background: transparent;
    border: 1px solid transparent;
    transition: transform 120ms ease, border-color 120ms ease, background-color 120ms ease;
  }

  .email-char:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--color-accent) 75%, transparent);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .email-copy {
    position: absolute;
    top: 12px;
    right: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    border: none;
    background: rgb(255 255 255 / 0.02);
    color: rgb(255 255 255 / 0.82);
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms ease, transform 120ms ease, background-color 120ms ease;
  }

  .email-copy svg {
    width: 12px;
    height: 12px;
  }

  .email-card.revealed .email-copy {
    opacity: 1;
    pointer-events: auto;
  }

  .email-copy:hover {
    transform: translateY(-1px);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .email-copy.copied {
    background: color-mix(in srgb, var(--color-accent) 18%, transparent);
  }

  .email-card.pulse {
    animation: reveal-pulse 320ms ease-out;
  }

  @keyframes grid-drift {
    from { background-position: 0 0, 0 0; }
    to { background-position: 28px 0, 0 28px; }
  }

  @keyframes scanline {
    from { transform: translateY(-100%); }
    to { transform: translateY(100%); }
  }

  @keyframes reveal-pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 0%, transparent); }
    30% { box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-accent) 40%, transparent), 0 0 32px color-mix(in srgb, var(--color-accent) 28%, transparent); }
    100% { box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-accent) 20%, transparent), 0 0 24px color-mix(in srgb, var(--color-accent) 12%, transparent); }
  }

  @media (max-width: 640px) {
    .contact-panel {
      --email-card-width: min(calc(100% - 40px), 494px);
      --email-card-height: min(calc((100% - 40px) * 0.5), 246px);
      width: 100%;
      height: calc(var(--email-card-height) * 1.4);
    }

    .email-card {
      width: var(--email-card-width);
      height: var(--email-card-height);
      margin: 0;
      padding: 16px;
    }

    .email-display {
      grid-template-columns: repeat(var(--email-char-count), 22px);
      gap: 2px;
    }

    .email-char {
      width: 22px;
      height: 34px;
      font-size: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-panel::before,
    .contact-panel::after,
    .email-card.pulse {
      animation: none;
    }
  }
</style>
