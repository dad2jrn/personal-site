---
interface Metric {
  label: string;
  value: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---

<section class="py-12">
  <div class="container-site">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {metrics.map((metric) => (
        <div class="bg-surface-sunken rounded-lg p-5 border border-line">
          <div class="label-mono mb-2">{metric.label}</div>
          <div class="text-3xl font-medium text-ink">{metric.value}</div>
        </div>
      ))}
    </div>
  </div>
</section>