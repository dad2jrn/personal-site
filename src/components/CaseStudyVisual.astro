---
interface Props {
  company: string;
}

const { company } = Astro.props;
---

<div class="w-full h-full relative overflow-hidden bg-surface-sunken flex items-center justify-center min-h-[200px]">
  {company.toLowerCase().includes('capital one') ? (
    <svg class="w-full h-full opacity-40 dark:opacity-60" viewBox="0 0 400 225" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="0.5" class="text-ink-subtle/20"/>
        </pattern>
      </defs>
      <rect width="400" height="225" fill="url(#grid)" />

      <!-- Abstract Data Nodes -->
      <g class="animate-pulse">
        <circle cx="100" cy="80" r="3" fill="#3b82f6" />
        <circle cx="300" cy="140" r="3" fill="#3b82f6" />
        <circle cx="200" cy="112" r="4" fill="#3b82f6" />
      </g>

      <!-- Connecting Lines -->
      <path d="M100 80 L200 112 L300 140" stroke="#3b82f6" stroke-width="1" opacity="0.3" stroke-dasharray="4 4" />
      <path d="M50 150 L200 112 L350 50" stroke="#3b82f6" stroke-width="1" opacity="0.2" />

      <!-- Moving "Packets" -->
      <circle r="2" fill="#3b82f6">
        <animateMotion dur="3s" repeatCount="indefinite" path="M100 80 L200 112 L300 140" />
      </circle>
      <circle r="2" fill="#3b82f6">
        <animateMotion dur="4s" repeatCount="indefinite" path="M350 50 L200 112 L50 150" />
      </circle>
    </svg>
  ) : (
    <svg class="w-full h-full opacity-40 dark:opacity-60" viewBox="0 0 400 225" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Architectural Blueprint Style -->
      <defs>
        <pattern id="dots" width="20" height="20" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="currentColor" class="text-ink-subtle/30" />
        </pattern>
      </defs>
      <rect width="400" height="225" fill="url(#dots)" />

      <!-- Geometric Governance Shapes -->
      <rect x="80" y="40" width="240" height="145" stroke="currentColor" stroke-width="1" opacity="0.4" />
      <rect x="100" y="60" width="200" height="105" stroke="#3b82f6" stroke-width="1" opacity="0.4" />

      <!-- Crosshairs -->
      <line x1="200" y1="0" x2="200" y2="225" stroke="currentColor" stroke-width="0.5" opacity="0.2" />
      <line x1="0" y1="112.5" x2="400" y2="112.5" stroke="currentColor" stroke-width="0.5" opacity="0.2" />

      <!-- Corner Accents -->
      <path d="M80 60 L80 40 L100 40" stroke="#3b82f6" stroke-width="2" />
      <path d="M300 165 L320 165 L320 145" stroke="#3b82f6" stroke-width="2" />
    </svg>
  )}

  <div class="absolute inset-0 bg-gradient-to-t from-surface-sunken via-transparent to-transparent"></div>
  <span class="absolute bottom-4 left-4 label-mono text-[10px] opacity-40">{company} // ARCH_VISUAL_v1.0</span>
</div>