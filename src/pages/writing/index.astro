---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('writing', ({ data }: CollectionEntry<'writing'>) => !data.draft);
const sortedPosts = posts.sort((a: CollectionEntry<'writing'>, b: CollectionEntry<'writing'>) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const formatDate = (date: Date | string) => {
  const d = typeof date === 'string' ? new Date(date) : date;
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<BaseLayout title="Writing & Essays">
  <section class="py-24">
    <div class="container-site">
      <h1 class="text-5xl font-medium text-ink mb-8">Writing</h1>
      <p class="text-xl text-ink-muted max-w-[60ch]">
        Thoughts on enterprise architecture, engineering leadership, and the intersection of technology and business strategy.
      </p>
    </div>
  </section>

  <section class="py-24 bg-surface-sunken border-t border-line">
    <div class="container-site">
      <div class="max-w-[800px] space-y-16">
        {sortedPosts.map((post: CollectionEntry<'writing'>) => (
          <article class="group">
            <div class="label-mono mb-4">{formatDate(post.data.publishedAt)}</div>
            <a href={`/writing/${post.slug}/`} class="block">
              <h2 class="text-3xl font-medium text-ink group-hover:text-accent transition-colors mb-4">
                {post.data.title}
              </h2>
              <p class="text-xl text-ink-muted leading-relaxed mb-6">
                {post.data.dek}
              </p>
              <div class="flex items-center gap-2 text-sm font-medium text-ink group-hover:gap-3 transition-all">
                Read essay <span>→</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>