---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PatentCard from '../../components/PatentCard.astro';

const patents = await getCollection('patents');
---

<BaseLayout title="Intellectual Property & Patents">
  <section class="py-24">
    <div class="container-site">
      <h1 class="text-5xl font-medium text-ink mb-8">Patents</h1>
      <p class="text-xl text-ink-muted max-w-[60ch]">
        Inventions and intellectual property developed during my tenure at Capital One, focusing on cloud infrastructure state management and automated software delivery.
      </p>
    </div>
  </section>

  <section class="py-24 bg-surface-sunken border-t border-line">
    <div class="container-site">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {patents.map((patent: CollectionEntry<'patents'>) => (
          <PatentCard entry={patent} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>