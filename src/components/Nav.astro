---
import ThemeToggle from './ThemeToggle.astro';

const { currentPath = "" } = Astro.props;

const navItems = [
  { label: 'work', href: '/personal-site/work/' },
  { label: 'patents', href: '/personal-site/patents/' },
  { label: 'writing', href: '/personal-site/writing/' },
  { label: 'contact', href: '/personal-site/contact/' },
];

const isActive = (href: string) => {
  const normalizedPath = currentPath.replace(/^\/|\/$/g, '');
  const normalizedHref = href.replace(/^\/personal-site\//, '').replace(/\/$/, '');

  if (normalizedHref === '' && normalizedPath === '') return true;
  if (normalizedHref !== '' && normalizedPath.startsWith(normalizedHref)) return true;
  return false;
};
---

<nav class="py-8">
  <div class="container-site flex items-center justify-between">
    <a href="/personal-site/" class="group flex items-center gap-1 font-display text-2xl font-medium tracking-tight text-ink">
      RM<span class="text-accent">.</span>
    </a>

    <div class="flex items-center gap-6 md:gap-10">
      <ul class="flex items-center gap-4 md:gap-8">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "font-mono text-[11px] uppercase tracking-mono-wide transition-all duration-150 hover:text-ink",
                isActive(item.href) ? "text-ink underline decoration-accent decoration-2 underline-offset-4" : "text-ink-muted underline decoration-transparent decoration-1 underline-offset-4 hover:decoration-ink-subtle"
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="h-4 w-px bg-line"></div>

      <ThemeToggle />
    </div>
  </div>
</nav>