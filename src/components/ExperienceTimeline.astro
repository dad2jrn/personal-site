---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'experience'>[];
  limit?: number;
  showViewAll?: boolean;
  enableModal?: boolean;
}

const { entries, limit, showViewAll = false, enableModal = false } = Astro.props;

const sortedEntries = entries.sort((a, b) => a.data.order - b.data.order);
const displayEntries = limit ? sortedEntries.slice(0, limit) : sortedEntries;

const formatYear = (dateStr: string) => dateStr.split('-')[0];
const formatSector = (sector: string) => {
  if (sector === 'fortune-100') return 'Banking';
  return sector.replace(/[-_]/g, ' ').replace(/\b\w/g, (char) => char.toUpperCase());
};
const modalEntries = displayEntries.map((entry) => ({
  period: `${formatYear(entry.data.startDate)} — ${entry.data.endDate ? formatYear(entry.data.endDate) : 'Present'}`,
  role: entry.data.role,
  company: entry.data.company,
  location: entry.data.location,
  sector: formatSector(entry.data.sector),
  summary: entry.data.summary,
  achievements: entry.data.achievements ?? [],
}));
---

<section class="py-24">
  <div class="container-site">
    <div class="flex items-center justify-between mb-12">
      <div class="label-mono">— Selected work</div>
      <div class="label-mono">2002 → now</div>
    </div>

    <div class="space-y-0">
      {displayEntries.map((entry, index) => (
        enableModal ? (
          <button
            type="button"
            class="experience-row group grid w-full grid-cols-1 gap-4 py-8 hairline text-left md:grid-cols-[120px_1fr_150px]"
            data-experience-trigger
            data-experience-index={String(index)}
            aria-haspopup="dialog"
            aria-controls="experience-role-modal"
          >
            <div class="font-mono text-sm text-ink-subtle">
              {formatYear(entry.data.startDate)} — {entry.data.endDate ? formatYear(entry.data.endDate) : 'Present'}
            </div>
            <div>
              <h3 class="text-xl font-medium text-ink transition-colors group-hover:text-accent">{entry.data.role}</h3>
              <p class="mt-1 text-ink-muted">{entry.data.company}</p>
              <p class="mt-3 max-w-[72ch] text-sm leading-relaxed text-ink-muted">{entry.data.summary}</p>
            </div>
            <div class="md:text-right">
              <div class="label-mono">{formatSector(entry.data.sector)}</div>
              <div class="mt-3 font-mono text-[11px] uppercase tracking-mono-wide text-accent transition-colors group-hover:text-ink">View details</div>
            </div>
          </button>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-[120px_1fr_150px] gap-4 py-8 hairline items-baseline">
            <div class="font-mono text-sm text-ink-subtle">
              {formatYear(entry.data.startDate)} — {entry.data.endDate ? formatYear(entry.data.endDate) : 'Present'}
            </div>
            <div>
              <h3 class="text-xl font-medium text-ink">{entry.data.role}</h3>
              <p class="text-ink-muted mt-1">{entry.data.company}</p>
            </div>
            <div class="label-mono md:text-right">
              {formatSector(entry.data.sector)}
            </div>
          </div>
        )
      ))}
    </div>

    {enableModal && (
      <>
        <script id="experience-modal-data" type="application/json" set:html={JSON.stringify(modalEntries)}></script>
        <div id="experience-role-modal" class="experience-modal" hidden aria-hidden="true">
          <div class="experience-modal__backdrop" data-experience-close></div>
          <div
            class="experience-modal__panel"
            role="dialog"
            aria-modal="true"
            aria-labelledby="experience-modal-title"
            aria-describedby="experience-modal-summary"
            tabindex="-1"
          >
            <button type="button" class="experience-modal__close" data-experience-close aria-label="Close role details">×</button>
            <div class="experience-modal__top">
              <div id="experience-modal-period" class="font-mono text-xs uppercase tracking-mono-wide text-ink-subtle"></div>
              <div id="experience-modal-sector" class="label-mono"></div>
            </div>
            <h3 id="experience-modal-title" class="mt-4 text-2xl font-medium text-ink"></h3>
            <p id="experience-modal-company" class="mt-2 text-base text-ink-muted"></p>
            <p id="experience-modal-location" class="mt-1 font-mono text-xs uppercase tracking-mono-wide text-ink-subtle"></p>
            <p id="experience-modal-summary" class="mt-6 text-base leading-relaxed text-ink-muted"></p>
            <ul id="experience-modal-achievements" class="mt-6 space-y-3 text-sm leading-relaxed text-ink-muted"></ul>
          </div>
        </div>
      </>
    )}

    {showViewAll && (
      <div class="mt-12 hairline pt-8">
        <a href="/work/" class="group inline-flex items-center gap-2 text-sm font-medium text-ink-muted hover:text-ink transition-colors">
          view full timeline <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>
    )}
  </div>
</section>

{enableModal && (
  <script is:inline>
    const setupExperienceModal = () => {
      const modal = document.getElementById('experience-role-modal');
      const panel = modal?.querySelector('.experience-modal__panel');
      const dataNode = document.getElementById('experience-modal-data');
      const triggers = Array.from(document.querySelectorAll('[data-experience-trigger]'));
      if (!modal || !panel || !dataNode || triggers.length === 0) return () => {};

      const title = document.getElementById('experience-modal-title');
      const company = document.getElementById('experience-modal-company');
      const period = document.getElementById('experience-modal-period');
      const location = document.getElementById('experience-modal-location');
      const sector = document.getElementById('experience-modal-sector');
      const summary = document.getElementById('experience-modal-summary');
      const achievements = document.getElementById('experience-modal-achievements');
      const closeTargets = Array.from(modal.querySelectorAll('[data-experience-close]'));
      if (!title || !company || !period || !location || !sector || !summary || !achievements) return () => {};

      let entries = [];
      try {
        entries = JSON.parse(dataNode.textContent ?? '[]');
      } catch {
        entries = [];
      }

      let activeTrigger = null;
      let isOpen = false;
      let previousBodyOverflow = '';

      const openModal = (index, trigger) => {
        const entry = entries[index];
        if (!entry) return;
        activeTrigger = trigger;
        title.textContent = entry.role;
        company.textContent = entry.company;
        period.textContent = entry.period;
        location.textContent = entry.location;
        sector.textContent = entry.sector;
        summary.textContent = entry.summary;
        achievements.textContent = '';
        achievements.hidden = entry.achievements.length === 0;
        entry.achievements.forEach((item) => {
          const li = document.createElement('li');
          li.className = 'experience-modal__achievement';
          li.textContent = item;
          achievements.appendChild(li);
        });
        previousBodyOverflow = document.body.style.overflow;
        document.body.style.overflow = 'hidden';
        modal.hidden = false;
        modal.setAttribute('aria-hidden', 'false');
        isOpen = true;
        window.requestAnimationFrame(() => panel.focus());
      };

      const closeModal = () => {
        if (!isOpen) return;
        isOpen = false;
        modal.hidden = true;
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = previousBodyOverflow;
        if (activeTrigger && document.contains(activeTrigger)) activeTrigger.focus();
        activeTrigger = null;
      };

      const onTriggerClick = (event) => {
        const trigger = event.currentTarget;
        const index = Number(trigger.dataset.experienceIndex ?? '-1');
        if (index < 0) return;
        openModal(index, trigger);
      };

      const onCloseClick = () => {
        closeModal();
      };

      const onKeydown = (event) => {
        if (!isOpen) return;
        if (event.key === 'Escape') {
          event.preventDefault();
          closeModal();
          return;
        }
        if (event.key !== 'Tab') return;
        const focusables = Array.from(panel.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'));
        if (focusables.length === 0) {
          event.preventDefault();
          panel.focus();
          return;
        }
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        const current = document.activeElement;
        if (event.shiftKey && current === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && current === last) {
          event.preventDefault();
          first.focus();
        }
      };

      triggers.forEach((trigger) => trigger.addEventListener('click', onTriggerClick));
      closeTargets.forEach((target) => target.addEventListener('click', onCloseClick));
      document.addEventListener('keydown', onKeydown);

      return () => {
        closeModal();
        triggers.forEach((trigger) => trigger.removeEventListener('click', onTriggerClick));
        closeTargets.forEach((target) => target.removeEventListener('click', onCloseClick));
        document.removeEventListener('keydown', onKeydown);
      };
    };

    let teardownExperienceModal = setupExperienceModal();

    document.addEventListener('astro:before-swap', () => {
      teardownExperienceModal();
      teardownExperienceModal = () => {};
    });

    document.addEventListener('astro:after-swap', () => {
      teardownExperienceModal();
      teardownExperienceModal = setupExperienceModal();
    });

    window.addEventListener('beforeunload', () => {
      teardownExperienceModal();
    });
  </script>

  <style>
    .experience-row {
      align-items: baseline;
      border: 0;
      background: transparent;
      transition: background-color 160ms ease;
    }

    .experience-row:hover {
      background: rgb(var(--surface-sunken) / 0.5);
    }

    .experience-modal {
      position: fixed;
      inset: 0;
      z-index: 70;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .experience-modal[hidden] {
      display: none;
    }

    .experience-modal__backdrop {
      position: absolute;
      inset: 0;
      background: rgb(0 0 0 / 0.58);
    }

    .experience-modal__panel {
      position: relative;
      z-index: 1;
      width: min(760px, 100%);
      max-height: min(86vh, 860px);
      overflow-y: auto;
      border: 1px solid rgb(var(--line-strong));
      border-radius: 12px;
      background: rgb(var(--surface-raised));
      padding: 28px;
      box-shadow: 0 24px 72px rgb(0 0 0 / 0.25);
    }

    .experience-modal__top {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 8px 16px;
      padding-right: 40px;
    }

    .experience-modal__close {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 32px;
      height: 32px;
      border: 1px solid rgb(var(--line));
      border-radius: 999px;
      background: rgb(var(--surface));
      color: rgb(var(--ink));
      font-size: 18px;
      line-height: 1;
      cursor: pointer;
      transition: border-color 150ms ease, color 150ms ease;
    }

    .experience-modal__close:hover {
      border-color: rgb(var(--accent) / 0.55);
      color: rgb(var(--accent));
    }

    .experience-modal__achievement {
      position: relative;
      padding-left: 16px;
    }

    .experience-modal__achievement::before {
      content: '•';
      position: absolute;
      left: 0;
      color: rgb(var(--accent));
    }

    @media (max-width: 640px) {
      .experience-modal {
        padding: 12px;
      }

      .experience-modal__panel {
        padding: 22px;
      }
    }
  </style>
)}