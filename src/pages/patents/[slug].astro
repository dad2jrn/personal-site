---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';

export async function getStaticPaths() {
  const patents = await getCollection('patents');
  return patents.map((entry: CollectionEntry<'patents'>) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'patents'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title}>
  <article class="py-24">
    <div class="container-site">
      <div class="max-w-[800px]">
        <div class="mb-12">
          <Breadcrumb segments={[{ label: 'PATENTS', href: '/patents/' }, { label: `${entry.id}.log`.toUpperCase() }]} />
        </div>

        <div class="label-mono text-accent mb-4">{entry.data.patentNumber}</div>
        <h1 class="h-display mb-8 text-[clamp(36px,5vw,72px)] text-ink">
          {entry.data.title}
        </h1>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 py-8 border-y border-line mb-12">
          <div>
            <div class="text-[10px] font-mono uppercase tracking-widest text-ink-subtle mb-1">Status</div>
            <div class="text-sm font-medium text-ink">Granted</div>
          </div>
          <div>
            <div class="text-[10px] font-mono uppercase tracking-widest text-ink-subtle mb-1">Date</div>
            <div class="text-sm font-medium text-ink">{entry.data.grantedDate}</div>
          </div>
          <div>
            <div class="text-[10px] font-mono uppercase tracking-widest text-ink-subtle mb-1">Assignee</div>
            <div class="text-sm font-medium text-ink">{entry.data.assignee}</div>
          </div>
          <div>
            <div class="text-[10px] font-mono uppercase tracking-widest text-ink-subtle mb-1">USPTO</div>
            <a href={entry.data.usptoUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-accent hover:text-ink transition-colors">View Original</a>
          </div>
        </div>

        <div class="prose max-w-none text-lg leading-relaxed mb-16">
          <Content />
        </div>

        <div class="mt-24 pt-12 border-t border-line">
          <div class="bg-surface-sunken p-8 border border-line">
            <h3 class="text-xl font-medium text-ink mb-4">Scale Fluency</h3>
            <p class="text-ink-muted leading-relaxed">
              The work behind this patent touched the kind of footprint where a 5% efficiency gain translates into real dollars and a 0.1% reliability improvement translates into thousands of customers having a better day. It represents the discipline required to operate cloud at the scale of a major bank.
            </p>
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>