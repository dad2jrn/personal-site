---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('writing', ({ data }: CollectionEntry<'writing'>) => !data.draft);
// Dated posts sort newest-first; undated posts (no publishedAt yet) fall after them, alphabetically.
const sortedPosts = posts.sort((a: CollectionEntry<'writing'>, b: CollectionEntry<'writing'>) => {
  const ad = a.data.publishedAt ? new Date(a.data.publishedAt).getTime() : -Infinity;
  const bd = b.data.publishedAt ? new Date(b.data.publishedAt).getTime() : -Infinity;
  if (ad !== bd) return bd - ad;
  return a.data.title.localeCompare(b.data.title);
});

const formatDate = (date: Date | string) => {
  const d = typeof date === 'string' ? new Date(date) : date;
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<BaseLayout title="Writing & Essays">
  <section class="py-24">
    <div class="container-site">
      <div class="eyebrow mb-8">/ FIELD NOTES</div>
      <h1 class="h-display mb-8 text-[clamp(48px,7vw,96px)] text-ink">Writing</h1>
      <p class="text-xl text-ink-muted max-w-[60ch]">
        Thoughts on enterprise architecture, engineering leadership, and the intersection of technology and business strategy.
      </p>
    </div>
  </section>

  <section class="py-24 bg-surface-sunken border-t border-line">
    <div class="container-site">
      <div class="max-w-[800px] space-y-16">
        {sortedPosts.map((post: CollectionEntry<'writing'>) => (
          <article class="group">
            {post.data.publishedAt && <div class="label-mono mb-4">{formatDate(post.data.publishedAt)}</div>}
            <a href={`/writing/${post.id}/`} class="block">
              <h2 class="mb-4 text-[28px] font-extrabold tracking-[-0.01em] text-ink transition-colors group-hover:text-accent [font-stretch:112%]">
                {post.data.title}
              </h2>
              <p class="text-xl text-ink-muted leading-relaxed mb-6">
                {post.data.dek}
              </p>
              <div class="flex items-center gap-2 text-sm font-medium text-ink group-hover:gap-3 transition-all">
                Read essay <span>→</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>