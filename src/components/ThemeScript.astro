---
// No frontmatter logic — this is server-rendered as-is and runs synchronously
// in the browser BEFORE the first paint, preventing theme flash.
---
<script is:inline>
  (function () {
    try {
      document.documentElement.classList.add('dark');
      document.documentElement.style.colorScheme = 'dark';
    } catch (_) {}
  })();
</script>
