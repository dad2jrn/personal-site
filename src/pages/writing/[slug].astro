---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts.map((entry: CollectionEntry<'writing'>) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'writing'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formatDate = (date: Date | string) => {
  const d = typeof date === 'string' ? new Date(date) : date;
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};
---

<BaseLayout title={entry.data.title}>
  <article class="py-24">
    <div class="container-site">
      <div class="max-w-[820px] mx-auto">
        {entry.data.publishedAt && <div class="label-mono mb-8">{formatDate(entry.data.publishedAt)}</div>}
        {entry.data.titleHtml ? (
          <h1 class="h-display mb-8 text-[clamp(28px,4vw,48px)] text-ink" set:html={entry.data.titleHtml} />
        ) : (
          <h1 class="h-display mb-8 text-[clamp(28px,4vw,48px)] text-ink">
            {entry.data.title}
          </h1>
        )}
        <p class="text-xl md:text-2xl text-ink-muted leading-relaxed mb-16">
          {entry.data.dek}
        </p>

        <div class="prose max-w-none text-lg">
          <Content />
        </div>

        <div class="mt-24 pt-12 border-t border-line">
          <div class="flex flex-wrap gap-2">
            {entry.data.tags.map((tag: string) => (
              <span class="px-3 py-1 bg-surface-sunken border border-line text-xs text-ink-subtle">
                #{tag}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>