---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404: Not Found">
  <section class="py-32">
    <div class="container-site text-center">
      <div class="eyebrow mb-8">ERROR 404</div>
      <h1 class="h-display mb-8 text-[clamp(36px,5vw,72px)] text-ink">
        Page not found
      </h1>
      <p class="text-xl text-ink-muted mb-12 max-w-[50ch] mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a href="/" class="btn-solid">BACK TO HOME →</a>
    </div>
  </section>
</BaseLayout>