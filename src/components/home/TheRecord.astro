---
import { getCollection } from 'astro:content';
import { CornerHandles, StatusDots } from './islands/boot/Greebles';

const entries = (await getCollection('experience')).length;
const patents = (await getCollection('patents')).length;
---

<section id="resume" class="px-6 pb-[60px] pt-[120px] md:px-10">
  <div class="mx-auto max-w-site">
    <div data-reveal class="mb-12 flex items-baseline gap-5">
      <span class="eyebrow">07 / THE RECORD</span>
      <div class="h-px flex-1 bg-ink/[0.14]"></div>
    </div>
    <div data-reveal data-flicker class="relative border border-line p-10">
      <div aria-hidden="true">
        <CornerHandles />
      </div>
      <div class="mb-8 flex flex-wrap items-center justify-between gap-4 border-b border-line pb-4" aria-hidden="true">
        <div class="flex items-center gap-2 font-mono text-[11px] tracking-[0.16em] text-ink/60">
          <span class="text-accent">&#9660;</span>
          <span>RM RESUME.LOG | <span class="text-accent">PERSONNEL FILE</span></span>
          <span class="ml-1 inline-block h-[12px] w-[7px] animate-[rm-blink_1.1s_steps(1)_infinite] bg-accent"></span>
        </div>
        <div class="flex items-center gap-3 font-mono text-[10px] tracking-[0.1em] text-ink/40">
          <StatusDots reduced={false} />
          <span>ARCHIVE RM97-2607</span>
        </div>
      </div>
      <div class="flex flex-wrap items-end justify-between gap-10">
        <div class="max-w-[600px]">
          <div class="mb-[10px] text-[28px] font-extrabold leading-[1.08] tracking-[-0.01em]">Twenty-five years of decisions, decrypted.</div>
          <p class="m-0 mb-4 text-[15px] leading-[1.7] text-ink-muted">Navy service to Fortune 100 payment platforms to statewide government — the complete service record renders as a live terminal session. Watch it type itself out, line by line.</p>
          <div class="font-mono text-[12px] tracking-[0.1em] text-ink/50">SPAN: 1997 &rarr; NOW &middot; ENTRIES: {entries} &middot; PATENTS: {patents}</div>
        </div>
        <a href="/resume/" class="btn-solid">LOAD RESUME.LOG &rarr;</a>
      </div>
    </div>
  </div>
</section>

<script>
  import { initCornerFlicker } from '../../scripts/flicker';
  initCornerFlicker();
</script>
