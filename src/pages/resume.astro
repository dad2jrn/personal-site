---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/home/SectionHeader.astro';
import ParticleField from '../components/home/islands/ParticleField';
import EmailDecoder from '../components/home/islands/EmailDecoder';
import { CornerHandles, LockBox, ArrayChip, StatusDots, MicroSelectRow } from '../components/home/islands/boot/Greebles';
import { site } from '../lib/site';

const experience = await getCollection('experience');
const sortedExperience = experience.sort((a: CollectionEntry<'experience'>, b: CollectionEntry<'experience'>) => a.data.order - b.data.order);

const featuredExperience = sortedExperience.filter(e => e.data.featured);
const previousExperience = sortedExperience.filter(e => !e.data.featured && e.data.resume);

const formatDate = (dateStr: string | null | undefined) => {
  if (!dateStr) return '';
  const parts = dateStr.split('-');
  if (parts.length < 2) return dateStr; // Return as is if not YYYY-MM
  const [year, month] = parts;
  const date = new Date(parseInt(year), parseInt(month) - 1);
  return date.toLocaleDateString('en-US', { month: '2-digit', year: 'numeric' });
};

const summary = "Enterprise architect who bridges business strategy and AI implementation, trusted by executives from Fortune 100 banks to state agencies to startup leadership. Helps organizations capture AI's value without betting the business on it, using safe-to-fail pilots, human-in-the-loop guardrails, and reversible deployment patterns that contain risk while proving measurable outcomes. 20+ years across regulated and enterprise-scale platforms.";

const skillGroups = [
  { label: "ENTERPRISE ARCHITECTURE", items: ["Architecture Governance", "Business Capability Modeling", "IT Strategy Alignment", "Platform Modernization", "Domain-driven Design"] },
  { label: "APPLIED AI & GOVERNANCE", items: ["Local LLM Tooling", "AI Solution Architecture (RAG, Copilots, Automation)", "AI-Assisted Development", "AI Readiness Assessment", "Prompt Engineering & Agentic Workflows", "LLM Platforms (Claude / MS Copilot / ChatGPT)", "Developer Productivity Evaluation"] },
  { label: "CLOUD & PLATFORMS", items: ["Azure", "AWS", "Cloud-Native Architecture", "Microservices", "API-Driven Platforms"] },
  { label: "ENGINEERING LEADERSHIP", items: ["Team Leadership", "Player-Coach Leadership", "Mentoring", "Cross-Functional Collaboration", "Executive Advisory"] },
  { label: "DELIVERY & OPERATIONS", items: ["DevOps", "CI/CD (Jenkins, GitHub Actions)", "Observability", "Reliability Engineering", "Agile/Scrum Methodology", "Performance Optimization"] },
  { label: "TECHNICAL", items: ["Python", "React.js", "TypeScript", "Node.js", "Java/Spring Boot", "Postgres", "Git", "Event-Driven Architecture"] },
];

const education = [
  { school: "Strayer University", degree: "BS, Computer Information Systems" },
  { school: "Strayer University", degree: "AA, Inter-networking Systems" },
];

const patents = [
  "Cloud Systems State Management",
  "Automated Software Roll-Forward / Rollback",
  "Least-Privilege Access Automation",
  "Terraform Infrastructure Modernization",
];
---

<BaseLayout title="Resume">
  <section class="relative overflow-hidden px-6 pb-[100px] pt-28 md:px-10 md:pt-32">
    <div class="no-print pointer-events-none absolute inset-0 opacity-40" aria-hidden="true">
      <ParticleField client:idle />
    </div>
    <div
      class="no-print pointer-events-none absolute inset-0 [background:radial-gradient(ellipse_at_50%_0%,rgba(10,10,11,0)_40%,rgba(10,10,11,0.92)_100%)]"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-[850px]">
      <div class="resume-panel relative border border-line bg-surface-raised/80 p-8 backdrop-blur-sm sm:p-12">
        <div class="no-print" aria-hidden="true">
          <CornerHandles />
        </div>
        {/* Full-panel CRT ambient layer: static scanline texture plus glow
            bands and thin sync lines all sweeping downward at offset periods.
            Clipped by an inner wrapper so the corner handles (which sit
            outside the panel edge) aren't cut off. Negative delays start the
            sweeps mid-flight so the panel never looks "empty" at load. */}
        <div class="no-print pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
          <div
            class="absolute inset-0"
            style="background: repeating-linear-gradient(to bottom, rgba(245,165,36,0.025) 0 1px, transparent 1px 5px);"
          ></div>
          <div
            class="absolute left-0 right-0 h-[40%] bg-linear-to-b from-accent/[0.05] to-transparent"
            style="animation: rm-scan 9s linear infinite;"
          ></div>
          <div
            class="absolute left-0 right-0 h-[22%] bg-linear-to-b from-accent/[0.03] to-transparent"
            style="animation: rm-scan 14s linear infinite -6s;"
          ></div>
          <div
            class="absolute left-0 right-0 h-px bg-accent/15"
            style="animation: rm-scan 7s linear infinite -3s;"
          ></div>
          <div
            class="absolute left-0 right-0 h-[2px] bg-accent/[0.08]"
            style="animation: rm-scan 11.5s linear infinite -8s;"
          ></div>
        </div>

        <!-- Terminal chrome bar -->
        <div class="no-print relative mb-10 flex flex-wrap items-center justify-between gap-4 border-b border-line pb-4" aria-hidden="true">
          <div class="flex items-center gap-2 font-mono text-[11px] tracking-[0.16em] text-ink/60">
            <span class="text-accent">&#9660;</span>
            <span>RM RESUME.LOG | <span class="text-accent">FULL RECORD</span></span>
            <span class="ml-1 inline-block h-[12px] w-[7px] animate-[rm-blink_1.1s_steps(1)_infinite] bg-accent"></span>
          </div>
          <div class="hidden sm:block">
            <LockBox code="RM97" />
          </div>
        </div>

        <!-- Header -->
        <header data-reveal class="mb-12 text-center">
          <div class="mb-4 flex flex-wrap items-center justify-center gap-x-3 gap-y-1 font-mono text-[12px] tracking-[0.14em] text-ink/50">
            <span>{site.location}</span>
            <span class="text-accent">&#9670;</span>
            <a href={`tel:${site.phone.replace(/\s+/g, '')}`} class="transition-colors hover:text-accent">{site.phone}</a>
            <span class="text-accent">&#9670;</span>
            <EmailDecoder client:visible className="no-underline transition-colors hover:text-accent" />
            <span class="text-accent">&#9670;</span>
            <a href={site.links.linkedin} class="transition-colors hover:text-accent">LinkedIn</a>
          </div>
          <h1 class="h-display m-0 text-[clamp(34px,6vw,60px)]">{site.name}</h1>
          <p class="mx-auto mt-3 max-w-[520px] font-serif text-[20px] italic leading-snug text-ink/85">{site.tagline}</p>
        </header>

        <!-- Download Action (Hidden in PDF) -->
        <div data-reveal class="no-print mb-12 flex flex-wrap items-center justify-center gap-x-12 gap-y-4 border border-line p-8 text-center">
          <p class="m-0 mb-2 w-full font-mono text-[12px] tracking-[0.1em] text-ink/50">NEED A PDF FOR YOUR RECORDS?</p>
          <a href={site.links.resumePdf} download class="btn-solid">DOWNLOAD PDF RESUME &#8595;</a>
          <a href={site.links.resumePdfAts} download class="btn-outline">ATS-FRIENDLY VERSION &#8595;</a>
        </div>

        <div class="space-y-14">
          <!-- Summary -->
          <section>
            <h2 class="sr-only">Summary</h2>
            <SectionHeader index="01" name="SUMMARY" />
            <p data-tline class="m-0 text-[15px] leading-[1.7] text-ink-muted">{summary}</p>
          </section>

          <!-- Work Experience -->
          <section>
            <h2 class="sr-only">Work Experience</h2>
            <SectionHeader index="02" name="WORK EXPERIENCE" />
            <div class="space-y-10">
              {featuredExperience.map((entry: CollectionEntry<'experience'>) => (
                <div>
                  <div data-tline class="mb-1 flex flex-wrap items-baseline justify-between gap-2">
                    <h3 class="text-[17px] font-bold text-ink">{entry.data.company}</h3>
                    <span class="font-mono text-[12px] tracking-[0.08em] text-ink/50">{formatDate(entry.data.startDate)} &ndash; {entry.data.endDate ? formatDate(entry.data.endDate) : 'Present'}</span>
                  </div>
                  <div data-tline class="mb-3 flex flex-wrap items-baseline justify-between gap-2">
                    <span class="font-serif text-[16px] italic text-ink/85">{entry.data.role}</span>
                    <span class="font-mono text-[12px] tracking-[0.08em] text-ink/40">{entry.data.location}</span>
                  </div>
                  <p data-tline class="mb-4 text-[14px] leading-relaxed text-ink-muted">
                    {entry.data.summary}
                  </p>
                  <ul class="ml-5 list-disc space-y-2 text-[14px] marker:text-accent">
                    {entry.data.achievements?.map((achievement: string) => (
                      <li data-tline class="pl-1 leading-relaxed text-ink-muted">
                        {achievement}
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>

          <!-- Previous Experience -->
          {previousExperience.length > 0 && (
            <section>
              <h2 class="sr-only">Previous Experience</h2>
              <SectionHeader index="03" name="PREVIOUS EXPERIENCE" />
              <div class="space-y-3">
                {previousExperience.map((entry: CollectionEntry<'experience'>) => (
                  <div data-tline class="grid grid-cols-[1fr_auto] items-baseline gap-4 text-[14px]">
                    <div class="truncate">
                      <span class="font-bold text-ink">{entry.data.role}</span>
                      <span class="mx-1 text-ink/30">|</span>
                      <span class="font-semibold text-ink/80">{entry.data.company}</span>
                      <span class="mx-1 text-ink/30">|</span>
                      <span class="italic text-ink/50">{entry.data.location}</span>
                    </div>
                    <span class="whitespace-nowrap font-mono text-[12px] tracking-[0.08em] text-ink/50">
                      {formatDate(entry.data.startDate)} &ndash; {entry.data.endDate ? formatDate(entry.data.endDate) : 'Present'}
                    </span>
                  </div>
                ))}
              </div>
            </section>
          )}

          <!-- Skills -->
          <section>
            <h2 class="sr-only">Skills</h2>
            <SectionHeader index="04" name="SKILLS" />
            <div class="space-y-5">
              {skillGroups.map((group, gi) => (
                <div>
                  <div data-tline class="mb-2 flex items-end justify-between gap-4">
                    <div class="font-mono text-[11px] tracking-[0.1em] text-ink/40">{group.label}</div>
                    {gi === 0 && (
                      <div class="no-print relative -top-7 hidden sm:block" aria-hidden="true">
                        <ArrayChip tag="SKL" code="6YT" />
                      </div>
                    )}
                  </div>
                  <div data-tline class="flex flex-wrap gap-2">
                    {group.items.map((s) => <span class="tag-chip">{s}</span>)}
                  </div>
                </div>
              ))}
            </div>
          </section>

          <!-- Education -->
          <section>
            <h2 class="sr-only">Education</h2>
            <SectionHeader index="05" name="EDUCATION" />
            <div class="space-y-4">
              {education.map((ed) => (
                <div data-tline class="flex flex-wrap items-baseline justify-between gap-2 text-[14px]">
                  <h3 class="text-[16px] font-bold text-ink">{ed.school}</h3>
                  <span class="italic text-ink/70">{ed.degree}</span>
                </div>
              ))}
            </div>
          </section>

          <!-- Patents -->
          <section>
            <h2 class="sr-only">Patents</h2>
            <SectionHeader index="06" name="PATENTS" />
            <ul class="m-0 ml-5 list-disc space-y-2 p-0 text-[14px] marker:text-accent">
              {patents.map((p) => (
                <li data-tline class="pl-1 leading-relaxed text-ink-muted">{p}</li>
              ))}
            </ul>
            <a href="/#patents" class="no-print mt-5 inline-block font-mono text-[12px] tracking-[0.12em] text-accent no-underline transition-colors hover:text-ink">FULL PATENT RECORDS &rarr;</a>
          </section>
        </div>

        <!-- Footer status strip -->
        <div data-reveal class="no-print mt-14 border-t border-line pt-4" aria-hidden="true">
          <div class="flex flex-wrap items-center justify-between gap-2 font-mono text-[10px] tracking-[0.1em] text-ink/40">
            <div class="flex items-center gap-3">
              <StatusDots reduced={false} />
              <span>TTY/2 :: RESUME EXPORT</span>
            </div>
            <div class="flex items-center gap-5">
              <div class="hidden sm:block">
                <MicroSelectRow code="REC 2607" period={2.4} reduced={false} />
              </div>
              <span class="text-accent">RECORD VERIFIED &middot; RM97-2607</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Terminal typewriter: one blinking block cursor types each [data-tline]
  // out character by character; lines join a single queue as they scroll
  // into view, so the cursor works top-to-bottom like real console output.
  //
  // Layout never shifts: on a line's turn its text nodes are split into
  // per-character spans that are invisible (visibility) but still occupy
  // their space, then flipped visible one by one with the cursor riding
  // the newest character. Hidden state is only ever applied by JS (no-JS
  // safe); reduced motion skips everything; the print rules force both
  // [data-tline] and .tc visible so nothing prints blank.
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const lines = Array.from(document.querySelectorAll<HTMLElement>('[data-tline]'));
  if (!reduced && lines.length) {
    lines.forEach((el, i) => {
      el.style.opacity = '0';
      el.dataset.ti = String(i);
    });

    // Split a line's text into per-char spans, skipping decorative
    // aria-hidden subtrees (e.g. the ArrayChip). Tag-chip borders hide
    // until their first character is typed so empty pills don't linger.
    const split = (line: HTMLElement): HTMLSpanElement[] => {
      const spans: HTMLSpanElement[] = [];
      const walker = document.createTreeWalker(line, NodeFilter.SHOW_TEXT, {
        acceptNode(n) {
          if (!n.nodeValue || !n.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
          for (let p = n.parentElement; p && p !== line; p = p.parentElement) {
            if (p.getAttribute('aria-hidden') === 'true') return NodeFilter.FILTER_REJECT;
          }
          return NodeFilter.FILTER_ACCEPT;
        },
      });
      const nodes: Text[] = [];
      while (walker.nextNode()) nodes.push(walker.currentNode as Text);
      for (const node of nodes) {
        const frag = document.createDocumentFragment();
        for (const ch of node.nodeValue!.replace(/\s+/g, ' ')) {
          const s = document.createElement('span');
          s.className = 'tc';
          s.textContent = ch;
          frag.appendChild(s);
          spans.push(s);
        }
        node.parentNode?.replaceChild(frag, node);
      }
      line.querySelectorAll<HTMLElement>('.tag-chip').forEach((c) => {
        c.style.visibility = 'hidden';
      });
      return spans;
    };

    const queue: { el: HTMLElement; i: number }[] = [];
    let active: { spans: HTMLSpanElement[]; i: number } | null = null;
    let cursor: HTMLElement | null = null;
    let raf = 0;

    const pump = () => {
      if (!active) {
        const next = queue.shift();
        if (!next) {
          raf = 0;
          cursor?.classList.add('tc-idle'); // park & blink at the last char
          return;
        }
        cursor?.classList.remove('tc-cur', 'tc-idle');
        cursor = null;
        next.el.style.opacity = '';
        active = { spans: split(next.el), i: 0 };
      }
      // Speed scales with backlog so fast scrolling never leaves the
      // cursor hopelessly behind (2–10 chars per frame ≈ 120–600 cps).
      const step = Math.min(10, 2 + queue.length);
      for (let k = 0; k < step && active; k++) {
        const s = active.spans[active.i];
        if (s) {
          s.classList.add('tc-on');
          const chip = s.closest<HTMLElement>('.tag-chip');
          if (chip && chip.style.visibility === 'hidden') chip.style.visibility = '';
          cursor?.classList.remove('tc-cur');
          s.classList.add('tc-cur');
          cursor = s;
        }
        active.i++;
        if (active.i >= active.spans.length) active = null;
      }
      raf = requestAnimationFrame(pump);
    };

    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        io.unobserve(e.target);
        const el = e.target as HTMLElement;
        queue.push({ el, i: Number(el.dataset.ti) });
        queue.sort((a, b) => a.i - b.i); // type in document order regardless of IO firing order
        if (!raf) raf = requestAnimationFrame(pump);
      }
    }, { threshold: 0.15 });
    lines.forEach((el) => io.observe(el));
  }

  if (!reduced) {
    // Corner-handle squares flicker sparsely and independently: a scheduler
    // fires at random intervals and picks 1–2 idle squares (never more than
    // 2 mid-flicker at once) for a short burst of 1–3 dips at random speed.
    // Any given square might flicker once in 30s or twice in 10s — there is
    // no rhythm to lock onto.
    const squares = Array.from(document.querySelectorAll<HTMLElement>('.resume-panel span.bg-ink'));
    if (squares.length) {
      let busy = 0;
      const flick = (sq: HTMLElement) => {
        busy++;
        const dips = 1 + Math.floor(Math.random() * 3);
        const dur = 0.12 + Math.random() * 0.28;
        sq.style.animation = `rm-flick-burst ${dur.toFixed(2)}s linear ${dips}`;
        setTimeout(() => {
          sq.style.animation = '';
          busy--;
        }, dur * dips * 1000 + 50);
      };
      const schedule = () => {
        setTimeout(() => {
          const want = Math.random() < 0.35 ? 2 : 1;
          const room = Math.min(want, 2 - busy);
          const idle = squares.filter((s) => !s.style.animation);
          for (let k = 0; k < room && idle.length; k++) {
            flick(idle.splice(Math.floor(Math.random() * idle.length), 1)[0]);
          }
          schedule();
        }, 1500 + Math.random() * 6500);
      };
      schedule();
    }

    // ArrayChip code: single letters mutate at random moments, like a
    // register being rewritten.
    const GLYPHS = 'ABCDEFGHJKLMNPQRSTUVWXYZ0123456789';
    document.querySelectorAll<HTMLElement>('[data-scramble]').forEach((el) => {
      const mutate = () => {
        const t = el.textContent ?? '';
        if (t.length) {
          const i = Math.floor(Math.random() * t.length);
          el.textContent = t.slice(0, i) + GLYPHS[Math.floor(Math.random() * GLYPHS.length)] + t.slice(i + 1);
        }
        setTimeout(mutate, 200 + Math.random() * 1400);
      };
      setTimeout(mutate, Math.random() * 800);
    });
  }
</script>

<style>
  /* Typewriter chars — :global because the spans are created by the script
     at runtime and never receive Astro's scoped-style attribute. Untyped
     chars keep their space (visibility, not display) so nothing reflows. */
  :global(.tc) {
    visibility: hidden;
  }
  :global(.tc-on) {
    visibility: visible;
  }
  :global(.tc-cur) {
    background: var(--color-accent);
    color: var(--color-surface);
  }
  :global(.tc-idle) {
    animation: rm-blink 1.1s steps(1) infinite;
  }

  @media print {
    .no-print {
      display: none !important;
    }
    /* Mid-type state must never print blank or inverse-video. */
    :global(.tc) {
      visibility: visible !important;
    }
    :global(.tc-cur),
    :global(.tc-idle) {
      background: transparent !important;
      animation: none !important;
    }
    section {
      padding-top: 0 !important;
      padding-bottom: 0 !important;
    }
    /* The dark on-screen theme (text-ink, text-accent, bg-surface-raised, etc.)
       sets color/background directly on individual elements, which the global
       `html, body { color: black !important }` print rule does not override
       (inherited values only apply where an element has no rule of its own).
       Force everything inside the panel back to plain black-on-white here.
       `:global()` is required on the descendant combinator because Astro's
       scoped-style attribute isn't carried onto child-component markup
       (e.g. SectionHeader's amber spans), so a plain `.resume-panel *`
       selector would never reach them. */
    .resume-panel,
    .resume-panel :global(*) {
      color: #000 !important;
      background: transparent !important;
      border-color: #000 !important;
      backdrop-filter: none !important;
    }
    .resume-panel :global(li::marker) {
      color: #000 !important;
    }
  }
</style>
