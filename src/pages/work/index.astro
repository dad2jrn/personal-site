---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExperienceTimeline from '../../components/ExperienceTimeline.astro';

const experience = await getCollection('experience');
const caseStudies = await getCollection('case-studies');

const sortedExperience = experience.sort((a: CollectionEntry<'experience'>, b: CollectionEntry<'experience'>) => a.data.order - b.data.order);
---

<BaseLayout title="Work & Experience">
  <section class="py-24">
    <div class="container-site">
      <h1 class="text-5xl font-medium text-ink mb-8">Work</h1>
      <p class="text-xl text-ink-muted max-w-[60ch]">
        A comprehensive timeline of my career in enterprise architecture, engineering leadership, and technology transformation.
      </p>
    </div>
  </section>

  <section class="py-24 bg-surface-sunken border-y border-line">
    <div class="container-site">
      <div class="label-mono mb-12">— Case Studies</div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {caseStudies.map((study: CollectionEntry<'case-studies'>) => (
          <a href={`/work/${study.slug}/`} class="group block">
            <div class="aspect-video bg-surface rounded-lg border border-line overflow-hidden mb-6">
              <div class="w-full h-full flex items-center justify-center text-ink-subtle group-hover:scale-105 transition-transform duration-500">
                <span class="label-mono">{study.data.company}</span>
              </div>
            </div>
            <h3 class="text-2xl font-medium text-ink group-hover:text-accent transition-colors mb-2">
              {study.data.title}
            </h3>
            <p class="text-ink-muted mb-4">
              {study.data.dek}
            </p>
            <div class="flex flex-wrap gap-2">
              {study.data.tools.map((tool: string) => (
                <span class="px-2 py-1 bg-surface border border-line rounded text-[10px] uppercase tracking-wider text-ink-subtle">
                  {tool}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <ExperienceTimeline entries={sortedExperience} />
</BaseLayout>